#ifndef ATOM_MONITOR__@MONITOR_NAME@
#define ATOM_MONITOR__@MONITOR_NAME@

#include "atom-base.h"
#include "hnl-instance.h"
#include "atom-identifier.h"
#include "verdict.h"

@namespace_start@

class AtomMonitor : public AtomBase<HNLInstance> {
  const AtomIdentifier _id;

public:
  virtual ~AtomMonitor() {}

  AtomMonitor(const AtomIdentifier& identifier) : AtomBase(std::get<0>(identifier)), _id(identifier) {}

  const AtomIdentifier& id() const { return _id; }

  virtual Verdict step(unsigned = 1) = 0;
};


///
// This is a monitor that has a cached verdict
// and returns only that from the step function
class AtomMonitorVerdict : public AtomMonitor {
  const Verdict _verdict;

public:

  AtomMonitorVerdict(const AtomIdentifier& identifier, Verdict v) : AtomMonitor(identifier), _verdict(v) {}

  Verdict step(unsigned) override { return _verdict; }
};



@namespace_end@

#endif // ATOM_MONITOR__@MONITOR_NAME@
